};


Circle::Circle() {
	radius = 1;
	cout << "¿¿¿" << radius << "¿ ¿¿" << endl;
}
Circle::Circle(int r) {
	radius = r;
	cout << "¿¿¿" << radius << "¿ ¿¿" << endl;

}

Circle::Circle(int a, int b) {
	radius = r;
	cout << "¿¿¿" << radius << "¿ ¿¿" << endl;

}

double Circle::getArea() {
	return 3.14 * radius * radius;
}

