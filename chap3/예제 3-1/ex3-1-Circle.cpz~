#include <iostream>
using namespace std;


class Circle {
public:
	int radius;
	double getArea()
		;
};

double Circle::getArea() {
	return 3.14 * radius * radius;
}

int main() {

	Circle donut;
	cout << " donut size : " << sizeof(donut) << endl;
	donut.radius = 1;
	double area = donut.getArea();
	cout << "donut ¿¿¿ " << area << endl;

	cout.setf(std::ios_base::fixed); // ios_base¿ namespace, fixed¿¿ ¿¿¿ ¿¿¿¿¿¿

	Circle pizza;
	pizza.radius = 30;
	area = pizza.getArea();
	cout << "pizza ¿¿¿ " << area << endl;

	cout.precision(10);
	cout << 3.14 << endl;


	return 0;
}
